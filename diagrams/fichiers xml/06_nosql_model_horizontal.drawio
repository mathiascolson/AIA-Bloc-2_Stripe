        <mxCell id="a4" edge="1" parent="1" source="ml" style="endArrow=block;html=1;rounded=0;strokeColor=#9673a6;strokeWidth=2;dashed=1;fontSize=13;entryX=0.452;entryY=1.001;entryDx=0;entryDy=0;entryPerimeter=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;labelBackgroundColor=none;" target="mongodb" value="scores de risque">
