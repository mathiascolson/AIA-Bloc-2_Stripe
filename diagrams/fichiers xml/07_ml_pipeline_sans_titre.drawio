        <mxCell id="subtitle" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#CBD5E1;fontColor=#334155;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" value="Collecte des événements → Feature Store → Entraînement → Scoring temps réel → Décision → Monitoring" vertex="1">
