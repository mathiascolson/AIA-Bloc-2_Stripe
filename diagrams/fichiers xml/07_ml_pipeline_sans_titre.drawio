        </mxCell>
        <mxCell id="n1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#0F172A;fontSize=12;align=center;verticalAlign=middle;spacing=6;" value="&lt;b&gt;1. Sources d’événements&lt;/b&gt;&lt;br&gt;&lt;br&gt;API Stripe&lt;br&gt;Paiements&lt;br&gt;Remboursements / litiges&lt;br&gt;Parcours utilisateur&lt;br&gt;Données appareil et localisation" vertex="1">
