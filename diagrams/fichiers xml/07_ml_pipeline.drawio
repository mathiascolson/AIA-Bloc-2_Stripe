<mxfile host="app.diagrams.net">
  <diagram name="ML Fraud Detection Pipeline" id="0">
    <mxGraphModel dx="1664" dy="853" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d9e3ec;strokeColor=#4f6475;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;" value="Pipeline ML de détection du risque Stripe — ingénierie des features, scoring et monitoring" vertex="1">
          <mxGeometry height="60" width="1240" x="80" y="30" as="geometry" />
        </mxCell>
        <mxCell id="sources" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b7cde8;strokeColor=#4f6f92;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" value="&lt;div&gt;&lt;b&gt;1. Sources d’événements&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;span&gt;API Stripe&lt;/span&gt;&lt;br&gt;&lt;span&gt;Paiements&lt;/span&gt;&lt;br&gt;&lt;span&gt;Remboursements / litiges&lt;/span&gt;&lt;br&gt;&lt;span&gt;Parcours utilisateur&lt;/span&gt;&lt;br&gt;&lt;span&gt;Données appareil et localisation&lt;/span&gt;" vertex="1">
          <mxGeometry height="150" width="210" x="40" y="300" as="geometry" />
        </mxCell>
        <mxCell id="collection" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6c989;strokeColor=#9a7a24;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" value="&lt;b&gt;2. Couche de collecte des événements&lt;/b&gt;&lt;br&gt;&lt;br&gt;Bus d’événements Apache Kafka&lt;br&gt;&lt;br&gt;&lt;b&gt;Rôle :&lt;/b&gt;&lt;br&gt;Collecter, ordonner et distribuer les événements produits par les API et applications" vertex="1">
          <mxGeometry height="150" width="300" x="300" y="300" as="geometry" />
        </mxCell>
        <mxCell id="nosql" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b7d7b9;strokeColor=#5e8a62;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" value="&lt;b&gt;3. Événements NoSQL / Feature Store&lt;/b&gt;&lt;br&gt;&lt;br&gt;MongoDB / stockage documentaire&lt;br&gt;&lt;br&gt;&lt;b&gt;Stockage :&lt;/b&gt;&lt;br&gt;clickstream_events&lt;br&gt;application_logs&lt;br&gt;risk_events&lt;br&gt;ml_feature_snapshots" vertex="1">
          <mxGeometry height="190" width="250" x="650" y="277" as="geometry" />
        </mxCell>
        <mxCell id="feature_engineering" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a6d8d5;strokeColor=#4e8d89;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" value="&lt;b&gt;4. Ingénierie des features&lt;/b&gt;&lt;br&gt;&lt;br&gt;Features batch&lt;br&gt;Features temps réel&lt;br&gt;Features comportement client&lt;br&gt;Features risque marchand&lt;br&gt;Features appareil / localisation" vertex="1">
          <mxGeometry height="150" width="250" x="650" y="570" as="geometry" />
        </mxCell>
        <mxCell id="training" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d9b8f3;strokeColor=#8f5db7;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" value="&lt;b&gt;5. Entraînement du modèle&lt;/b&gt;&lt;br&gt;&lt;br&gt;Modèle de détection du risque&lt;br&gt;Jeux d’entraînement&lt;br&gt;Métriques de validation&lt;br&gt;Suivi des expériences&lt;br&gt;Registre des modèles" vertex="1">
          <mxGeometry height="150" width="230" x="1000" y="570" as="geometry" />
        </mxCell>
        <mxCell id="scoring" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4a9df;strokeColor=#8e55a1;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" value="&lt;b&gt;6. API de scoring temps réel&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Entrées :&lt;/b&gt;&lt;br&gt;Contexte transactionnel&lt;br&gt;Features client&lt;br&gt;Features marchand&lt;br&gt;&lt;br&gt;&lt;b&gt;Sorties :&lt;/b&gt;&lt;br&gt;risk_score&lt;br&gt;risk_level&lt;br&gt;risk_decision" vertex="1">
          <mxGeometry height="180" width="230" x="1000" y="300" as="geometry" />
        </mxCell>
        <mxCell id="decision" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f2b8bd;strokeColor=#b35c65;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" value="&lt;b&gt;7. Moteur de décision opérationnelle&lt;/b&gt;&lt;br&gt;&lt;br&gt;Valider&lt;br&gt;Revue manuelle&lt;br&gt;Bloquer&lt;br&gt;Demander une vérification complémentaire&lt;br&gt;&lt;br&gt;Renvoie la décision au flux de paiement" vertex="1">
          <mxGeometry height="150" width="290" x="970" y="120" as="geometry" />
        </mxCell>
        <mxCell id="monitoring" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d8c492;strokeColor=#947a34;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" value="&lt;b&gt;8. Monitoring et réentraînement&lt;/b&gt;&lt;br&gt;&lt;br&gt;Dérive des prédictions&lt;br&gt;Dérive des features&lt;br&gt;Suivi du taux de risque&lt;br&gt;Analyse des faux positifs&lt;br&gt;Déclencheurs de réentraînement" vertex="1">
          <mxGeometry height="150" width="220" x="340" y="570" as="geometry" />
        </mxCell>
        <mxCell id="analytics" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f2b8bd;strokeColor=#b35c65;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" value="&lt;b&gt;Analytique Snowflake / dbt&lt;/b&gt;&lt;br&gt;&lt;br&gt;Reporting du risque&lt;br&gt;Analyse de performance modèle&lt;br&gt;Reporting de conformité&lt;br&gt;Investigations historiques" vertex="1">
          <mxGeometry height="150" width="220" x="70" y="570" as="geometry" />
